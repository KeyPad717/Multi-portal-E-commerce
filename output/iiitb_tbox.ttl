@prefix edu: <http://semanticweb.iiitb.ac.in/edu#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu:NewsItem a owl:Class ;
    rdfs:label "NewsItem"@en ;
    rdfs:comment "News article or event published by the institution"@en ;
    owl:equivalentClass schema:NewsArticle .

edu:PGProgram a owl:Class ;
    rdfs:label "PGProgram"@en ;
    rdfs:comment "Postgraduate / masters programme (M.Tech, PGD, etc.)"@en ;
    rdfs:subClassOf edu:AcademicProgram .

edu:PlacementRecord a owl:Class ;
    rdfs:label "PlacementRecord"@en ;
    rdfs:comment "Placement / recruitment record"@en .

edu:ResearchProgram a owl:Class ;
    rdfs:label "ResearchProgram"@en ;
    rdfs:comment "Research programme (PhD, MS by Research)"@en ;
    rdfs:subClassOf edu:AcademicProgram .

edu:Staff a owl:Class ;
    rdfs:label "Staff"@en ;
    rdfs:comment "Administrative / technical staff member"@en ;
    rdfs:subClassOf foaf:Person ;
    owl:equivalentClass foaf:Person .

edu:StudentActivity a owl:Class ;
    rdfs:label "StudentActivity"@en ;
    rdfs:comment "Student club, committee or campus event"@en .

edu:UGProgram a owl:Class ;
    rdfs:label "UGProgram"@en ;
    rdfs:comment "Undergraduate programme (B.Tech, etc.)"@en ;
    rdfs:subClassOf edu:AcademicProgram .

edu:admissionDeadline a owl:DatatypeProperty ;
    rdfs:label "admissionDeadline"@en ;
    rdfs:comment "Applications deadline"@en ;
    rdfs:range xsd:string .

edu:belongsTo a owl:ObjectProperty ;
    rdfs:label "belongsTo"@en ;
    rdfs:comment "Faculty/Staff/Lab belongs to Institution"@en ;
    rdfs:range edu:Institution .

edu:bio a owl:DatatypeProperty ;
    rdfs:label "bio"@en ;
    rdfs:comment "Biographical information"@en ;
    rdfs:range xsd:string .

edu:body a owl:DatatypeProperty ;
    rdfs:label "body"@en ;
    rdfs:comment "Full body text scraped from the page"@en ;
    rdfs:range xsd:string .

edu:category a owl:DatatypeProperty ;
    rdfs:label "category"@en ;
    rdfs:comment "Source category from scraper"@en ;
    rdfs:range xsd:string .

edu:collaboratesWith a owl:ObjectProperty ;
    rdfs:label "collaboratesWith"@en ;
    rdfs:comment "Institution collaborates with ExternalOrg"@en ;
    rdfs:domain edu:Institution ;
    rdfs:range edu:ExternalOrg .

edu:description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Textual description"@en ;
    rdfs:range xsd:string .

edu:designation a owl:DatatypeProperty ;
    rdfs:label "designation"@en ;
    rdfs:comment "Job title / designation"@en ;
    rdfs:range xsd:string .

edu:email a owl:DatatypeProperty ;
    rdfs:label "email"@en ;
    rdfs:comment "Email address"@en ;
    rdfs:range xsd:string .

edu:fee a owl:DatatypeProperty ;
    rdfs:label "fee"@en ;
    rdfs:comment "Programme fee per semester"@en ;
    rdfs:range xsd:string .

edu:governs a owl:ObjectProperty ;
    rdfs:label "governs"@en ;
    rdfs:comment "GovernanceMember governs Institution"@en ;
    rdfs:domain edu:GovernanceMember ;
    rdfs:range edu:Institution .

edu:hasDepartment a owl:ObjectProperty ;
    rdfs:label "hasDepartment"@en ;
    rdfs:comment "Institution has Department"@en ;
    rdfs:domain edu:Institution ;
    rdfs:range edu:Department .

edu:hasLab a owl:ObjectProperty ;
    rdfs:label "hasLab"@en ;
    rdfs:comment "Institution/Department has Lab"@en ;
    rdfs:range edu:Lab .

edu:hasResearchArea a owl:ObjectProperty ;
    rdfs:label "hasResearchArea"@en ;
    rdfs:comment "Faculty/Lab has ResearchArea"@en ;
    rdfs:range edu:ResearchArea .

edu:heading a owl:DatatypeProperty ;
    rdfs:label "heading"@en ;
    rdfs:comment "Section heading extracted from the page"@en ;
    rdfs:range xsd:string .

edu:name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Full name of the entity"@en ;
    rdfs:range xsd:string .

edu:offers a owl:ObjectProperty ;
    rdfs:label "offers"@en ;
    rdfs:comment "Institution offers AcademicProgram"@en ;
    rdfs:domain edu:Institution ;
    rdfs:range edu:AcademicProgram .

edu:partOf a owl:ObjectProperty ;
    rdfs:label "partOf"@en ;
    rdfs:comment "Department is part of Institution"@en ;
    rdfs:domain edu:Department ;
    rdfs:range edu:Institution .

edu:publishedDate a owl:DatatypeProperty ;
    rdfs:label "publishedDate"@en ;
    rdfs:comment "Date of publication (news/events)"@en ;
    rdfs:range xsd:string .

edu:relatedTo a owl:ObjectProperty ;
    rdfs:label "relatedTo"@en ;
    rdfs:comment "Generic semantic relation between any entities"@en .

edu:scrapedAt a owl:DatatypeProperty ;
    rdfs:label "scrapedAt"@en ;
    rdfs:comment "Timestamp when this data was scraped"@en ;
    rdfs:range xsd:dateTime .

edu:slug a owl:DatatypeProperty ;
    rdfs:label "slug"@en ;
    rdfs:comment "URL slug identifier"@en ;
    rdfs:range xsd:string .

edu:supervisedBy a owl:ObjectProperty ;
    rdfs:label "supervisedBy"@en ;
    rdfs:comment "ResearchScholar supervised by Faculty"@en ;
    rdfs:domain edu:ResearchScholar ;
    rdfs:range edu:Faculty .

edu:url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "Web URL of the entity"@en ;
    rdfs:range xsd:anyURI .

edu:worksIn a owl:ObjectProperty ;
    rdfs:label "worksIn"@en ;
    rdfs:comment "Faculty/Scholar works in Lab"@en ;
    rdfs:range edu:Lab .

edu:ExternalOrg a owl:Class ;
    rdfs:label "ExternalOrg"@en ;
    rdfs:comment "External organisation referenced by the institution"@en ;
    owl:equivalentClass foaf:Organization .

edu:Faculty a owl:Class ;
    rdfs:label "Faculty"@en ;
    rdfs:comment "Academic faculty member / professor"@en ;
    rdfs:subClassOf foaf:Person ;
    owl:equivalentClass foaf:Person .

edu:GovernanceMember a owl:Class ;
    rdfs:label "GovernanceMember"@en ;
    rdfs:comment "Governing body / board member"@en ;
    rdfs:subClassOf foaf:Person ;
    owl:equivalentClass foaf:Person .

edu:ResearchArea a owl:Class ;
    rdfs:label "ResearchArea"@en ;
    rdfs:comment "Research domain / topic (SKOS concept)"@en ;
    owl:equivalentClass skos:Concept .

edu:ResearchScholar a owl:Class ;
    rdfs:label "ResearchScholar"@en ;
    rdfs:comment "PhD / MS research scholar"@en ;
    rdfs:subClassOf foaf:Person ;
    owl:equivalentClass foaf:Person .

edu:Department a owl:Class ;
    rdfs:label "Department"@en ;
    rdfs:comment "Academic department within an institution"@en ;
    rdfs:subClassOf edu:Institution ;
    owl:equivalentClass schema:Organization .

edu:Lab a owl:Class ;
    rdfs:label "Lab"@en ;
    rdfs:comment "Research lab or centre at the institution"@en ;
    owl:equivalentClass schema:ResearchProject .

edu:AcademicProgram a owl:Class ;
    rdfs:label "AcademicProgram"@en ;
    rdfs:comment "Academic programme offered by an institution"@en ;
    owl:equivalentClass schema:EducationalOccupationalProgram .

edu:Institution a owl:Class ;
    rdfs:label "Institution"@en ;
    rdfs:comment "Educational institution (university, college, etc.)"@en ;
    owl:equivalentClass schema:EducationalOrganization .

