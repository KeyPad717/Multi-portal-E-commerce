    <rdfs:label xml:lang="en">CAGS-IIITB – CENTRE FOR ACCESSIBILITY IN THE GLOBAL SOUTH, IIIT BANGALORE</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CAGS-IIITB – CENTRE FOR ACCESSIBILITY IN THE GLOBAL SOUTH, IIIT BANGALORE</edu:name>
