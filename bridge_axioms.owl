<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:cse="https://cse.iiitb.ac.in#"
    xmlns:ece="https://ece.iiitb.ac.in#"
    xmlns:dept="http://iiitb.ac.in/ontology/departments#"
    xmlns:prog="http://iiitb.ac.in/ontology/programmes#"
    xmlns:bridge="http://iiitb.ac.in/ontology/bridge#">

  <!-- Equivalent Classes -->
  <owl:Class rdf:about="https://cse.iiitb.ac.in#Department">
    <owl:equivalentClass rdf:resource="http://iiitb.ac.in/ontology/programmes#Department"/>
  </owl:Class>
  <owl:Class rdf:about="https://ece.iiitb.ac.in#Fieldofstudy">
    <owl:equivalentClass rdf:resource="http://iiitb.ac.in/ontology/programmes#FieldOfStudy"/>
  </owl:Class>
  <owl:Class rdf:about="https://cse.iiitb.ac.in#Researchfield">
    <owl:equivalentClass rdf:resource="http://iiitb.ac.in/ontology/programmes#FieldOfStudy"/>
  </owl:Class>
  <owl:Class rdf:about="https://ece.iiitb.ac.in#Researchfield">
    <owl:equivalentClass rdf:resource="http://iiitb.ac.in/ontology/programmes#FieldOfStudy"/>
  </owl:Class>
  <owl:Class rdf:about="https://cse.iiitb.ac.in#Educationalinstitution">
    <owl:equivalentClass rdf:resource="http://iiitb.ac.in/ontology/programmes#Institution"/>
  </owl:Class>

  <!-- Equivalent Properties -->
  <owl:ObjectProperty rdf:about="https://cse.iiitb.ac.in#hasResearchArea">
    <owl:equivalentProperty rdf:resource="http://iiitb.ac.in/ontology/programmes#hasFieldOfStudy"/>
  </owl:ObjectProperty>

  <!-- Custom ObjectProperties -->
  <owl:ObjectProperty rdf:about="http://iiitb.ac.in/ontology/bridge#managedBy">
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/programmes#AcademicProgramme"/>
    <rdfs:range rdf:resource="https://cse.iiitb.ac.in#Department"/>
  </owl:ObjectProperty>

  <!-- Links between Programmes and Departments -->
  <prog:IMTechECE rdf:about="http://iiitb.ac.in/ontology/programmes#IMTechECE">
    <bridge:managedBy rdf:resource="https://ece.iiitb.ac.in#Department"/>
  </prog:IMTechECE>
  <prog:B_Tech_CSE rdf:about="http://iiitb.ac.in/ontology/programmes#B_Tech_CSE">
    <bridge:managedBy rdf:resource="https://cse.iiitb.ac.in#Department"/>
  </prog:B_Tech_CSE>
  <prog:M_Tech_ECE rdf:about="http://iiitb.ac.in/ontology/programmes#M_Tech_ECE">
    <bridge:managedBy rdf:resource="https://ece.iiitb.ac.in#Department"/>
  </prog:M_Tech_ECE>
  <prog:M_Tech_AIDS rdf:about="http://iiitb.ac.in/ontology/programmes#M_Tech_AIDS">
    <bridge:managedBy rdf:resource="https://cse.iiitb.ac.in#Department"/>
  </prog:M_Tech_AIDS>

</rdf:RDF>