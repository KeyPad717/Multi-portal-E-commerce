    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PIONEERING ADVANCED COMMUNICATIONS AND NURTURING NEXT-GEN INNOVATORS</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://comet.iiitb.ac.in/</edu:url>
