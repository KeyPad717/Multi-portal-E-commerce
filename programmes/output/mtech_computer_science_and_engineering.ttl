@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix onto: <http://iiitb.ac.in/ontology/autonomous#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

onto: a owl:Ontology ;
    dc:description "Emergent OWL ontology generated by autonomous pipeline."@en ;
    dc:title "Autonomous Institutional Knowledge Graph"@en ;
    owl:versionInfo "3.0-emergent" .

onto:M_Tech_CSE a onto:PostgraduateProgram,
        owl:NamedIndividual ;
    onto:hasGoal onto:DevelopProfessionals ;
    onto:hasSection onto:Courses,
        onto:Internships,
        onto:ProjectWork,
        onto:Research,
        onto:Seminars .

onto:hasGoal a owl:ObjectProperty ;
    rdfs:comment "Relates an academic program to its goal" ;
    rdfs:domain onto:AcademicProgram ;
    rdfs:range onto:Goal .

onto:hasSection a owl:ObjectProperty ;
    rdfs:comment "Relates an academic program to its section" ;
    rdfs:domain onto:AcademicProgram ;
    rdfs:range onto:Section .

onto:Courses a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Courses of study" .

onto:DevelopProfessionals a onto:EducationGoal,
        owl:NamedIndividual ;
    rdfs:comment "Develop professionals of high quality" .

onto:EducationGoal a owl:Class ;
    rdfs:comment "A goal related to education" ;
    rdfs:subClassOf onto:Goal .

onto:Internships a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Internships" .

onto:PostgraduateProgram a owl:Class ;
    rdfs:comment "A postgraduate academic program" ;
    rdfs:subClassOf onto:AcademicProgram .

onto:ProjectWork a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Project work" .

onto:Research a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Research leading to a thesis" .

onto:Seminars a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Seminars" .

onto:Goal a owl:Class ;
    rdfs:comment "A goal or objective" .

onto:AcademicProgram a owl:Class ;
    rdfs:comment "The concept of an academic program" .

onto:Section a owl:Class ;
    rdfs:comment "A section or component of an academic program" .

