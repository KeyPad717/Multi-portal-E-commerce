  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpscagsiiitbacincategoryworkshops">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
