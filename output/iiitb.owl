  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/student_activity_Events">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#StudentActivity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Events</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Events</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/events-and-festivals/events</edu:url>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infin8 is an inter College Cultural Festival organized by IIIT-B every year. It is a three-day event packed with simulation games, cultural activities, fun field games and much more. Taking break from SPIC MACAY (Society for the Promotion of Indian Classical Music and Culture Amongst Youth) is a non-political, nationwide, voluntary movement founded in 1977 by Dr Kiran Seth, Professor-Emeritus Spandan, IIIT-B’s annual sports organized by the Sports team in the month of March every year. The three-day event is fully loaded with outdoor as well as indoor games. We seek active participation Sangam</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:37</edu:scrapedAt>
    <edu:heading rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Infin8</edu:heading>
    <edu:heading rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Yamini</edu:heading>
    <edu:heading rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spandan</edu:heading>
    <edu:heading rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sangam</edu:heading>
    <edu:heading rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Confluence</edu:heading>
    <edu:heading rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Synergy</edu:heading>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
