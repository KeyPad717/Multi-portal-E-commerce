  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/faculty#person1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/faculty#Person"/>
    <rdfs:label xml:lang="en">Chandrashekar Ramanathan</rdfs:label>
    <onto:prop_role>['Professor', 'Researcher', 'Administrator']</onto:prop_role>
    <onto:prop_university>IIIT-B</onto:prop_university>
    <onto:prop_title>TSAPI: Enhancing Existing OLTP Databases with Temporal Query Capabilities for Analytics</onto:prop_title>
    <onto:prop_bio>Faculty member at IIIT-B since 2007</onto:prop_bio>
    <onto:prop_expertise>['Data Science', 'Software Engineering', 'Large Scale Application Development']</onto:prop_expertise>
    <onto:prop_teaching_interests>['Data Modeling', 'Data Analytics', 'Database Design', 'Software Architecture']</onto:prop_teaching_interests>
    <onto:prop_research_focus>['Data Science', 'Model-based Software Engineering', 'Technology for Education']</onto:prop_research_focus>
    <onto:prop_phd_degree>Ph.D. (Mississippi State University)</onto:prop_phd_degree>
    <onto:prop_phd_research_focused>Object-Oriented Databases</onto:prop_phd_research_focused>
    <onto:worksAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">organization1</onto:worksAt>
    <onto:hasResearchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">research_area1</onto:hasResearchArea>
    <onto:hasResearchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">research_area2</onto:hasResearchArea>
    <onto:hasResearchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">research_area3</onto:hasResearchArea>
    <onto:hasResearchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">research_area4</onto:hasResearchArea>
    <onto:hasResearchArea rdf:datatype="http://www.w3.org/2001/XMLSchema#string">research_area5</onto:hasResearchArea>
    <onto:authorOf rdf:datatype="http://www.w3.org/2001/XMLSchema#string">publication1</onto:authorOf>
    <onto:relatedTo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">concept1</onto:relatedTo>
    <onto:relatedTo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">concept2</onto:relatedTo>
    <onto:relatedTo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">concept3</onto:relatedTo>
    <onto:relatedTo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">concept4</onto:relatedTo>
    <onto:relatedTo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">concept5</onto:relatedTo>
  </rdf:Description>
