  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_Mr_Naresh_Shah">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Mr. Naresh Shah</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mr. Naresh Shah</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/governing-body/naresh-shah</edu:url>
    <edu:bio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Naresh Shah joined Hewlett Packard Enterprise in 2011 as President for the Enterprise Group R&amp;D organization in India. The Bangalore center is a strategic R&amp;D center for the Enterprise Group. Naresh also has global engineering accountability for products such as Integrity HP-UX Servers. Before HP, Naresh worked at Novell for 4 years as Managing Director of Novell’s India Development Center and 20 years at AT&amp;T and its spin-off Lucent Technologies in the US where he held various leadership positions in engineering, product management, and sales. Naresh holds a B.Tech. in Computer Science and Engineering from IIT, Kharagpur and M.S. in Computer and Information Science from the Ohio State University, Columbus. He has also completed leadership development program in partnership with the Harvard Business School, and Executive Education programs at Tufts University, University of Richmond, and Thunderbird.</edu:bio>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:09:14</edu:scrapedAt>
    <edu:governs rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
