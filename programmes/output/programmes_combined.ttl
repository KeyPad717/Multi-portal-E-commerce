@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix onto: <http://iiitb.ac.in/ontology/autonomous#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

onto: a owl:Ontology ;
    dc:description "Emergent OWL ontology generated by autonomous pipeline."@en ;
    dc:title "Autonomous Institutional Knowledge Graph"@en ;
    owl:versionInfo "3.0-emergent" .

onto:B_Tech_AIDS a onto:Degree,
        owl:NamedIndividual ;
    onto:hasFieldOfStudy onto:ArtificialIntelligenceAndDataScience ;
    onto:hasName "B.Tech. (Artificial Intelligence & Data Science)"^^<xsd:string> .

onto:B_Tech_CSE a onto:Degree,
        owl:NamedIndividual ;
    onto:hasFieldOfStudy onto:ComputerScienceAndEngineering ;
    onto:hasName "B.Tech. (Computer Science and Engineering)"^^<xsd:string> .

onto:B_Tech_ECE a onto:Degree,
        owl:NamedIndividual ;
    onto:hasFieldOfStudy onto:ElectronicsAndCommunicationEngineering ;
    onto:hasName "B.Tech. (Electronics and Communication Engineering)"^^<xsd:string> .

onto:IMTechECE a onto:AcademicProgramme,
        owl:NamedIndividual ;
    onto:hasBio "IIIT-B introduced a 5-year Integrated M.Tech. (I.M.Tech.) programme from 2012 onwards. The Integrated M.Tech. programme is a 5-year integrated programme intended for students who have completed or are completing Plus Two (or equivalent). At the end of five years of the programme, successful students get dual degrees of B.Tech and M.Tech. The students will be taught and supervised by the faculty members with PhD from highly reputed universities of the world and involved in R&D in niche areas of ECE." ;
    onto:hasDegree onto:BTechDegree,
        onto:MTechDegree ;
    onto:hasFacultyMember onto:ECEFacultyMember ;
    onto:hasTitle "Integrated M.Tech. (Electronics and Communication Engineering)" ;
    onto:offeredBy onto:IIITB .

onto:IMTechProgramme a onto:AcademicProgramme,
        owl:NamedIndividual ;
    onto:hasBio "IIIT-B introduced a 5-year Integrated M.Tech. (I.M.Tech.) programme in 2012. The Integrated M.Tech. programme is a 5-year integrated programme intended for students who have completed or are completing Plus Two of schooling (or equivalent). At the end of five years of the programme, successful students get dual degrees of B.Tech. and M.Tech.&nbsp;&nbsp;The students will be taught and supervised by the faculty members with PhD from highly reputed universities of the world and involved in R&amp;D in niche areas of CSE." ;
    onto:hasDegree onto:BTechDegree,
        onto:MTechDegree ;
    onto:hasFacultyMember onto:FacultyMember1 ;
    onto:hasInstitution onto:IIITB ;
    onto:hasName "Integrated M.Tech (Computer Science and Engineering)" .

onto:M_Tech_AIDS a onto:PostgraduateProgramme,
        owl:NamedIndividual ;
    onto:hasGoal onto:DevelopProfessionals ;
    onto:hasSection onto:Courses,
        onto:Internships,
        onto:ProjectWork,
        onto:Research,
        onto:Seminars .

onto:M_Tech_CSE a onto:PostgraduateProgram,
        owl:NamedIndividual ;
    onto:hasGoal onto:DevelopProfessionals ;
    onto:hasSection onto:Courses,
        onto:Internships,
        onto:ProjectWork,
        onto:Research,
        onto:Seminars .

onto:M_Tech_ECE a onto:PostgraduateProgramme,
        owl:NamedIndividual ;
    onto:hasGoal onto:DevelopProfessionals ;
    onto:hasSection onto:Courses,
        onto:Internships,
        onto:ProjectWork,
        onto:ResearchLeadingToThesis,
        onto:Seminars .

onto:hasBio a owl:DatatypeProperty ;
    rdfs:comment "Represents a brief description of an academic programme",
        "Represents the bio of an academic programme" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range <xsd:string> .

onto:hasDegree a owl:ObjectProperty ;
    rdfs:comment "Relates an academic programme to a degree" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range onto:Degree .

onto:hasFacultyMember a owl:ObjectProperty ;
    rdfs:comment "Relates an academic programme to a faculty member" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range onto:FacultyMember .

onto:hasFieldOfStudy a owl:ObjectProperty ;
    rdfs:comment "Relates a degree to its field of study",
        "Relates an academic program to its field of study" ;
    rdfs:domain onto:AcademicProgram,
        onto:Degree ;
    rdfs:range onto:FieldOfStudy .

onto:hasGoal a owl:ObjectProperty ;
    rdfs:comment "Relates an academic program to its goal",
        "Relates an academic programme to its goals" ;
    rdfs:domain onto:AcademicProgram,
        onto:AcademicProgramme ;
    rdfs:range onto:Goal .

onto:hasInstitution a owl:ObjectProperty ;
    rdfs:comment "Relates an academic programme to an institution" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range onto:Institution .

onto:hasName a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:comment "Relates a degree to its name",
        "Relates an academic program to its name",
        "Represents the name of an academic programme" ;
    rdfs:domain onto:AcademicProgram,
        onto:AcademicProgramme,
        onto:Degree ;
    rdfs:range <xsd:string> .

onto:hasResearchArea a owl:ObjectProperty ;
    rdfs:comment "Relates a faculty member to a research area" ;
    rdfs:domain onto:FacultyMember ;
    rdfs:range onto:ResearchArea .

onto:hasSection a owl:ObjectProperty ;
    rdfs:comment "Relates an academic program to its section",
        "Relates an academic programme to its sections" ;
    rdfs:domain onto:AcademicProgram,
        onto:AcademicProgramme ;
    rdfs:range onto:Section .

onto:hasStudent a owl:ObjectProperty ;
    rdfs:comment "Relates an academic programme to a student" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range onto:Student .

onto:hasTitle a owl:DatatypeProperty ;
    rdfs:comment "Represents the title of an academic programme" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range <xsd:string> .

onto:involvedIn a owl:ObjectProperty ;
    rdfs:comment "Relates a faculty member to a research area" ;
    rdfs:domain onto:FacultyMember ;
    rdfs:range onto:ResearchArea .

onto:offeredBy a owl:ObjectProperty ;
    rdfs:comment "Relates an academic programme to an institution" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range onto:Institution .

onto:ArtificialIntelligenceAndDataScience a onto:FieldOfStudy,
        owl:NamedIndividual ;
    rdfs:comment "Represents the field of Artificial Intelligence and Data Science" .

onto:CSEResearchArea a onto:ResearchArea,
        owl:NamedIndividual ;
    rdfs:comment "Computer Science and Engineering research area" .

onto:ComputerScienceAndEngineering a onto:FieldOfStudy,
        owl:NamedIndividual .

onto:ECEFacultyMember a onto:FacultyMember,
        owl:NamedIndividual ;
    onto:involvedIn onto:ECEResearchArea .

onto:ECEResearchArea a onto:ResearchArea,
        owl:NamedIndividual ;
    rdfs:comment "Niche area of Electronics and Communication Engineering" .

onto:EducationGoal a owl:Class ;
    rdfs:comment "A goal related to education",
        "Represents a goal related to education" ;
    rdfs:subClassOf onto:Goal .

onto:ElectronicsAndCommunicationEngineering a onto:FieldOfStudy,
        owl:NamedIndividual ;
    rdfs:comment "Represents the field of Electronics and Communication Engineering" .

onto:FacultyMember1 a onto:FacultyMember,
        owl:NamedIndividual ;
    onto:hasResearchArea onto:CSEResearchArea .

onto:PostgraduateProgram a owl:Class ;
    rdfs:comment "A postgraduate academic program" ;
    rdfs:subClassOf onto:AcademicProgram .

onto:ResearchLeadingToThesis a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Research leading to a thesis" .

onto:Student a owl:Class ;
    rdfs:comment "Represents a student enrolled in an academic programme" .

onto:University a owl:Class ;
    rdfs:comment "Represents a university" ;
    rdfs:subClassOf onto:Institution .

onto:BTechDegree a onto:Degree,
        owl:NamedIndividual ;
    rdfs:comment "Bachelor of Technology degree" .

onto:Goal a owl:Class ;
    rdfs:comment "A goal or objective",
        "Represents a goal or objective" .

onto:IIITB a onto:Institution,
        onto:University,
        owl:NamedIndividual .

onto:MTechDegree a onto:Degree,
        owl:NamedIndividual ;
    rdfs:comment "Master of Technology degree" .

onto:PostgraduateProgramme a owl:Class ;
    rdfs:comment "Represents a postgraduate programme of study" ;
    rdfs:subClassOf onto:AcademicProgramme .

onto:Research a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Research leading to a thesis" .

onto:Courses a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Courses of study" .

onto:DevelopProfessionals a onto:EducationGoal,
        owl:NamedIndividual ;
    rdfs:comment "Develop professionals of high quality",
        "Develop professionals of high quality to cater to the needs of industry and academia" .

onto:Internships a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Internships" .

onto:ProjectWork a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Project work" .

onto:Seminars a onto:Section,
        owl:NamedIndividual ;
    rdfs:comment "Seminars" .

onto:FieldOfStudy a owl:Class ;
    rdfs:comment "Represents a field of study",
        "Represents a field of study or discipline" .

onto:Institution a owl:Class ;
    rdfs:comment "Represents an educational institution" .

onto:ResearchArea a owl:Class ;
    rdfs:comment "Represents a niche area of research" .

onto:FacultyMember a owl:Class ;
    rdfs:comment "Represents a faculty member involved in teaching and research" .

onto:AcademicProgram a owl:Class ;
    rdfs:comment "Represents an academic program",
        "Represents an academic program offered by an institution",
        "The concept of an academic program" .

onto:Section a owl:Class ;
    rdfs:comment "A section or component of an academic program",
        "Represents a section or component of a programme" .

onto:Degree a owl:Class ;
    rdfs:comment "Represents a degree",
        "Represents a degree awarded to students upon completion of a programme",
        "Represents a type of academic degree" ;
    rdfs:subClassOf onto:AcademicProgram .

onto:AcademicProgramme a owl:Class ;
    rdfs:comment "Represents a programme of study",
        "Represents an academic programme offered by an institution" .

