    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_generic</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:31</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The VLSI Systems domain encompasses a broad range of topics covering several aspects such as, digital and analog hardware systems, FPGA implementations, custom fabricated VLSI circuits, design methodologies around EDA flows, verification and validation, system prototyping. Further, it also includes realization of real time embedded systems where both the hardware and the software components are treated agnostically based on end system requirements; embedded implementation of feedback control using variegated sensors. We also focus on emerging technologies based on Micro and Nano-electro mechanical devices – fabrication of 2D/3D structures, characterization and system applications. Active areas of research can be classified in to the following domains:</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_Mr_Sanjeev_Malhotra">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Mr. Sanjeev Malhotra</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mr. Sanjeev Malhotra</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/governing-body/sanjeev-malhotra</edu:url>
    <edu:bio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">As a head of the NASSCOM Center of Excellence – IoT &amp; AI spanning four locations in Bangalore, Gurgaon, Vizag, and Ahmedabad, Sanjeev executed unique Industry partnership model for co-creating solutions with the startups focusing on emerging technologies like IoT, Artificial Intelligence, Robotics, etc. and its application in Healthcare, Life Science, Manufacturing, etc. Sanjeev started his career at Silicon Valley as designer on Pentium Processor subsequently lead product development, strategy &amp; global operations at Intel, Qualcomm, etc. He set up the Indian centers for global companies and has MBA from Duke University. Social media handle link: https://www.linkedin.com/in/sanjeevdupont/ Villa #264, Adarsh Palm Retreat, Bellandur, Bangalore - 560103 (Near Intel and Honeywell ORR)</edu:bio>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:09:15</edu:scrapedAt>
    <edu:governs rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
