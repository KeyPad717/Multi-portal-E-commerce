  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Mphasis">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Mphasis</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mphasis</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://cognitive.iiitb.ac.in/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_cognitive</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:07:47</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cognitive technology is transforming all aspects of enterprises and society today. This requires dedicated investments to build a world class ecosystem accessible for all. We are committed to building the first of its kind cognitive computing centre focusing on machine learning, deep learning, natural language processing, sensors and augmented reality. Mphasis, a leading IT solutions provider specializing in cloud and cognitive services, is collaborating with International Institute of Information Technology Bangalore (IIIT-B) in setting up this centre. This Centre will focus on applied research with relevance for society and enterprises. Mphasis will invest more than INR 50 M over the next three years on this initiative. Expected outcomes from the Mphasis – IIIT-B Centre of Excellence for</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
