  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_Srinath_Srinivasa">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Srinath Srinivasa</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Srinath Srinivasa</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/administration/srinath-srinivasa</edu:url>
    <edu:bio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Education : Ph.D. (Brandenburg Technical University Cottbus) Srinath Srinivasa heads the Web Science lab and is the Dean (R&amp;D) at IIIT Bangalore, India. Srinath holds a Ph.D (magna cum laude) from the Berlin Brandenburg Graduate School for Distributed Information Systems (GkVI) Germany, an M.S. (by Research) from IIT-Madras and B.E. in Computer Science and Engineering from The National Institute of Engineering (NIE) Mysore. He works in the area of Web Science — that models of the impact of the web on humanity. Technology for educational outreach and social empowerment has been a primary motivation driving his research. He has participated in several initiatives for technology enhanced education including the VTU Edusat program, The National Programme for Technology Enhanced Learning (NPTEL) and an educational outreach program in collaboration with Upgrad.  He is a member of various technical and organizational committees for international conferences like International Conference on We</edu:bio>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:34</edu:scrapedAt>
    <edu:governs rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
