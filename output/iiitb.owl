  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpsdhssiiitbacinemerging_opportunities_and_challenges_in_a_digital_society_a_citapp_symposium">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">‘Emerging opportunities and challenges in a digital society’ – A CITAPP Symposium</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">‘Emerging opportunities and challenges in a digital society’ – A CITAPP Symposium</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://dhss.iiitb.ac.in/emerging-opportunities-and-challenges-in-a-digital-society-a-citapp-symposium/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dhss_news</edu:category>
    <edu:publishedDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feb 8, 2024</edu:publishedDate>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feb 8, 2024 | Events , Symposium Artwork by Shivangi Garg , M.Sc. Digital Society Alumna (Class of 2022), incorporating from art by Lena Tokens. More on this artwork here What are the salient features, and the emerging opportunities and urgent challenges, of the digital society we inhabit today? This symposium will reflect on CITAPP’s work in this domain over the past several years, followed by the release of a survey report authored by itihaasa Research and Digital . The report sheds light on the experiences of 1800 respondents across socio-economic categories  from the Bangalore Urban region</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:12</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
