  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Welcome_to">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Welcome to</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Welcome to</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://ece.iiitb.ac.in/adec/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_ece</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:18</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Analog Design Evolution Collaborative, ADEC, is an initiative to connect industry professionals and students. Our goal is to explore new avenues in analog IC/systems design and combine theoretical insights with practical design approaches. Also, Analog IC/systems design is often considered part ’art,’ and through collaboration, we aim to put method to this art, helping our students learn and contribute in a more structured and meaningful way. Lastly, IIIT-Bangalore has expertise in different fields, and we also hope to collaborate with other functions and experts at IIIT, from Digital-CMOS to Embedded Systems to Machine Learning. We hope to collaborate meaningfully to contribute to the field. ADEC is more than just presentations. It is a foundation we are setting for Analog Design Research</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
