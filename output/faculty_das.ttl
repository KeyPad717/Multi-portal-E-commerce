@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix onto: <http://iiitb.ac.in/ontology/autonomous#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

onto: a owl:Ontology ;
    dc:description "Schema-less OWL ontology generated by autonomous semantic discovery pipeline."@en ;
    dc:title "Autonomous Institutional Knowledge Graph"@en ;
    owl:versionInfo "2.0-schema-less" .

onto:Chandrashekar_R a onto:Professor,
        owl:NamedIndividual ;
    rdfs:label "Chandrashekar Ramanathan" ;
    onto:email "rc@iiitb.ac.in" ;
    onto:leadsLab onto:CTRI-DG,
        onto:MINRO ;
    onto:servesAs "Board_of_Studies"^^xsd:string ;
    onto:servesOn "Technical_Advisory_Panel"^^xsd:string ;
    onto:supervisedStudent "PhD_students"^^xsd:string ;
    onto:wasMemberOf onto:BITES ;
    onto:worksAt onto:IIIT_B .

onto:Mississippi_State_University a onto:University,
        owl:NamedIndividual ;
    rdfs:label "Mississippi State University" .

onto:collaboratesWith a owl:SymmetricProperty .

onto:email a owl:DatatypeProperty ;
    rdfs:label "email" .

onto:hasEmail a owl:FunctionalProperty .

onto:servesAs a owl:DatatypeProperty ;
    rdfs:label "servesAs" ;
    rdfs:range onto:Board .

onto:servesOn a owl:DatatypeProperty ;
    rdfs:label "servesOn" ;
    rdfs:domain onto:Professor ;
    rdfs:range onto:Panel .

onto:supervisedStudent a owl:DatatypeProperty ;
    rdfs:label "supervisedStudent" .

onto:wasMemberOf a owl:ObjectProperty ;
    rdfs:label "wasMemberOf" .

onto:worksAt a owl:ObjectProperty ;
    rdfs:label "worksAt" ;
    rdfs:domain onto:Professor ;
    rdfs:range onto:University .

onto:BITES a onto:Organization,
        owl:NamedIndividual ;
    rdfs:label "Board for IT Education Standards" .

onto:CTRI-DG a onto:Lab,
        owl:NamedIndividual ;
    rdfs:label "Center for Technology Research and Innovation – Digital Governance" .

onto:Faculty a owl:Class ;
    rdfs:label "Faculty" ;
    rdfs:subClassOf onto:Person .

onto:IIIT_B a onto:University,
        owl:NamedIndividual ;
    rdfs:label "International Institute of Information Technology Bangalore" .

onto:MINRO a onto:Lab,
        owl:NamedIndividual ;
    rdfs:label "Machine Intelligence and Robotics Center" .

onto:Organization a owl:Class ;
    rdfs:label "Organization" .

onto:leadsLab a owl:ObjectProperty ;
    rdfs:label "leadsLab" ;
    rdfs:domain onto:Professor ;
    rdfs:range onto:Lab ;
    owl:inverseOf onto:ledBy .

onto:ledBy owl:inverseOf onto:leadsLab .

onto:Lab a owl:Class ;
    rdfs:label "Lab" .

onto:University a owl:Class ;
    rdfs:label "University" .

onto:Professor a owl:Class ;
    rdfs:label "Professor" ;
    rdfs:subClassOf onto:Faculty .

