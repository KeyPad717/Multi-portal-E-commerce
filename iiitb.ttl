    rdfs:label "Programme Outcomes" ;
    edu:belongsTo iiitb:iiitb ;
    edu:description "26/C, Opposite of Infosys Gate 10Electronics City Phase 1, Hosur RoadBengaluru - 560100 © 2026 IIIT-Bangalore. All Rights Reserved" ;
