@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix onto: <http://iiitb.ac.in/ontology/autonomous#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

onto: a owl:Ontology ;
    dc:description "Emergent OWL ontology generated by autonomous pipeline."@en ;
    dc:title "Autonomous Institutional Knowledge Graph"@en ;
    owl:versionInfo "3.0-emergent" .

onto:B_Tech_CSE a onto:Degree,
        owl:NamedIndividual ;
    onto:hasFieldOfStudy onto:ComputerScienceAndEngineering ;
    onto:hasName "B.Tech. (Computer Science and Engineering)"^^<xsd:string> .

onto:hasFieldOfStudy a owl:ObjectProperty ;
    rdfs:comment "Relates an academic program to its field of study" ;
    rdfs:domain onto:AcademicProgram ;
    rdfs:range onto:FieldOfStudy .

onto:hasName a owl:ObjectProperty ;
    rdfs:comment "Relates an academic program to its name" ;
    rdfs:domain onto:AcademicProgram ;
    rdfs:range <xsd:string> .

onto:ComputerScienceAndEngineering a onto:FieldOfStudy,
        owl:NamedIndividual .

onto:Degree a owl:Class ;
    rdfs:comment "Represents a type of academic degree" ;
    rdfs:subClassOf onto:AcademicProgram .

onto:FieldOfStudy a owl:Class ;
    rdfs:comment "Represents a field of study or discipline" .

onto:AcademicProgram a owl:Class ;
    rdfs:comment "Represents an academic program offered by an institution" .

