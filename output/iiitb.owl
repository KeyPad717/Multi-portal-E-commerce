  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpscagsiiitbacinevents_and_conferencesreimagining_pathways_for_assistive_technology">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Reimagining Pathways</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reimagining Pathways</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://cags.iiitb.ac.in/events-and-conferences/reimagining-pathways-for-assistive-technology/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cags_event</edu:category>
    <edu:publishedDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">April 22, 2025</edu:publishedDate>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NCPEDP in collaboration with CAGS, IIITB are pleased to host Re-imagining Pathways for Assistive Technology, a multistakeholder consultation designed to be a significant step towards creating an inclusive and vibrant AT ecosystem in India. This multi-stakeholder dialogue aims to spark transformative change, fostering new partnerships that will drive innovation, accessibility, and affordability in the Indian AT sector. By bringing together diverse stakeholders, the consultation seeks to explore fresh ideas, forge new collaborations, and outline actionable steps forward.</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:07:47</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
