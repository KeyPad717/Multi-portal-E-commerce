  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Department_of_Data_Science_and_Artificial_Intelligence">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Department of Data Science and Artificial Intelligence</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Department of Data Science and Artificial Intelligence</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://dsai.iiitb.ac.in/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_dsai</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:15</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discover how our department leads in Big Data, Multimodal AI, and cutting-edge research applications across various fields. Engage with diverse research areas from NLP to multimodal AI, driven by innovative ongoing projects. Stay updated with the latest breakthroughs and happenings in the world of data science and AI. Meet our expert faculty and dedicated researchers shaping the future of AI. Find out how you can join and contribute to our dynamic department. The department of Data Science and Artificial Intelligence (DSAI) is home to some of the best academics in the fields of Big data systems and management (including retrieval, analysis and visualisation ), Multimodal AI (including vision, graphics, language and speech) and DSAI algorithms (including reinforcement learning, self-supervi</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_DEPARTMENT_OF_DIGITAL_HUMANITIES_AND_SOCIETAL_SYSTEMS">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">DEPARTMENT OF DIGITAL HUMANITIES AND SOCIETAL SYSTEMS</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEPARTMENT OF DIGITAL HUMANITIES AND SOCIETAL SYSTEMS</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://dhss.iiitb.ac.in/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_dhss</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:07:59</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exploring the intersection of technology, humanities, and society at IIIT-Bangalore. A collaborative community of scholars, researchers, and students bridging tech and social sciences. Conducting interdisciplinary research to address societal challenges through digital innovation. Offering unique programs that combine technology with humanities and social sciences. Explore diverse opportunities to engage in research, internships, and community impact. Catch up on our latest projects, events, and departmental achievements. The Department of Digital Humanities and Societal Systems (D-HSS) has been created to underscore IIIT-Bangalore’s continued focus on the interdependent and mutually shaping nature of digital technologies and societies. The department seeks to engage with interdisciplinary</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpsdhssiiitbacinopportunities">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Opportunities</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Opportunities</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://dhss.iiitb.ac.in/opportunities/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dhss_news</edu:category>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Given the interdisciplinary focus of teaching and research at DHSS, we are particularly interested in faculty applicants having strong credentials in research and teaching spanning computing/digital technology and social sciences. 26/C, Opposite of Infosys gate 1 Electronics City Phase 1, Hosur Road Bengaluru – 560100</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:17</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Our_Offerings">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Our Offerings</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Our Offerings</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://ic.iiitb.ac.in/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_ic</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:17</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This program offers a dynamic platform for the convergence of digital technologies across diverse industry verticals, catalyzing deeptech solutions to emerge. Cutting-edge advancements in Artificial Intelligence, Blockchain, IoT, Quantum, and Data Analytics are at the core of this transformational program. Building the  Bridge between deep academic research and sharp startup acumen, we offer an ecosystem conducive to groundbreaking discoveries and disruptive solutions. To build a wholistic ecosystem encompassing all key stakeholders to nurture and support innovators and entrepreneurs to build deeptech solutions for India. To be a Technology Innovation Ecosystem to empower innovators to build the next generation Technology Solutions for Mankind. Access to faculty and industry mentors Access</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/student_activity_Cafeteria">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#StudentActivity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Cafeteria</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cafeteria</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/cafeteria</edu:url>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The institute is home to an ever expanding menu of fresh and inventive dining. Healthy nutrition is needed for all round performance and hence, the cafeteria has menus offering nutritious and wholesome food to ensure a well-balanced diet. IIIT-B cafeteria offers North-Indian delights to South-Indian cuisines, popular world delicacies, and also has an exclusive Jain food section. The menu is curated monthly by students’ food committee, keeping it in line with students’ taste buds. The committee interacts with the food vendors for the mess and café to decide the menu and also inspects hygiene co</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:22</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Precision_Learning_for_Enterprise">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Precision Learning for Enterprise</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Precision Learning for Enterprise</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://wsl.iiitb.ac.in/precision-learning-for-enterprise/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_wsl</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:19</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Organizational learning is fast becoming an integral element of the daily operations of organizations given the pace of change in technology and market dynamics. Organizational learning is the process of creating, retaining, and transferring knowledge within an organization. An organization improves over time as it gains experience. From this experience, it is able to create knowledge. This knowledge is broad, covering any topic that could better an organization. Organisational learning is an essential element for the survival of any organisation in this fast paced technological and business landscape. A concept of “learning organizations” has been a focus of enormous research and managerial interest since the early 1990s. Peter Senge, identifies five key disciplines for organizational lea</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_J_P_Patil">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">J P Patil</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">J P Patil</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/administration/j-p-patil</edu:url>
    <edu:bio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jagadish P Patil has joined IIITB as Chief Administrative Officer in 2015. He carries 30 plus years of experience in leading G2C Health Project, Large Manufacturing Operations, Environmental Services &amp; B2B Sales in MENA market. Before moving in to IIITB he was leading a large 24x7 Emergency system in Karnataka. He traveled across ME countries, commissioned a medium size manufacturing plant in Dubai  and led the factory operations for 7 plus years with full P&amp;L responsibilities.</edu:bio>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:33</edu:scrapedAt>
    <edu:governs rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/program_PhD_Master_of_Science_by_Research">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#ResearchProgram"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Ph.D. &amp; Master of Science by Research</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ph.D. &amp; Master of Science by Research</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/courses/master-of-science-by-researchdoctor-of-philosophy</edu:url>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:23</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Computer Science(CS): Algorithms, in general, and specifically, Graph and Geometric Algorithms, Graph Algorithms for IoT Networks. Cryptography, in general, and specifically, Privacy preserving ID verification using homomorphic encryption, Secure cryptographic implementations against side-channel attacks. Formal verification of machine learning algorithms and applications, Formal Verification and Architectural Analysis of Enterprise Applications (e.g. Digital public infrastructures), Testing of software systems (e.g.</edu:description>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Data Science &amp; Artificial Intelligence(DSAI): Remote Sensing, GIS and Geospatial Data Science, Digital Public Infrastructures (DPIs) LLMs and AI in Education , Streaming data systems, Neuro-Symbolic AI, 3D LiDAR point cloud processing, Analysis of chart images, Multimodal Conversational Agents, Action and activity recognition , 6D Object Pose Analysis, Language Guided navigation in 3D scenes, Topological Data Analysis, AI and Big Data, Reinforcement Learning, Large Language Models, Deep Learning, Machine Learning, AI and Big Data, Consent M</edu:description>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Digital Humanities and Societal Systems (DHSS): ICTD, Information Technology and Labour, Political Economy of Innovation, The Information Technology Industry, E-Governance and Digital Public Infrastructure. FACULTY INVOLVED: Prof Amit Prakash, Prof Balaji Parthasarathy, Prof Chinar Mehta, Prof V. Sridhar.</edu:description>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mathematics &amp; Physics(MP) [only PhD, Integrated PhD]: Mathematics: Pure Mathematics : Number Theory, in particular, Algebraic Number Theory, Diophantine Equations, Galois Module Structure and Elliptic Curves. FACULTY INVOLVED: Prof Manisha Kulkarni Applied Mathematics : Theoretical, numerical, &amp; computational analysis of thin-film flows, microfluidics &amp; fluid-porous interactions. Topics include: the analysis of drop spreading and evaporation of complex liquids on porous substrates, turbulence in thin-film flows, and stability in interfacial flows w</edu:description>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Networking,Communications &amp; Signal Processing (NCSP): Integrated Sensing and Communication (ISAC),Semantic communication for 6G wireless networks, Digital Twin for Industrial IoT, Security in Network Slicing, Zero Touch Networks, Beam management in 5G networks, Channel estimation in IRS systems, Transceiver Design for High Mobility Applications, Physical-layer Security, Robust Beamforming and Optimization for IRS-Assisted 6G Wireless Networks. FACULTY INVOLVED: Prof Debabrata Das, Prof Jyotsna Bapat, Prof V. Ramasubramanian, Prof Priyanka Das, Prof</edu:description>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Software Engineering(SE): Formal Verification and Architectural Analysis of Enterprise Applications (e.g. Digital public infrastructures), Testing of software systems (e.g. data-driven applications, platform software e.g. embedded, gaming and consumer electronics). Engineering software systems for regulatory compliance, accessibility, inclusiveness, security and trustworthiness. Design of computer languages (programming languages, specification and modelling languages etc.). Formal verification of embedded systems. FACUL</edu:description>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VLSI and Embedded Systems: VLSI Architecture Design, IoT systems, Biomedical systems, Assistive and surgical systems, Wearable Design, Rehabilitation Robotics, AI/ML Hardware Accelerators, AI for VLSI Placement and Routing, VLSI Architecture for Communication Systems, AI for Designing FPGA Architectures, Placement and Routing Algorithms for FPGA Design, AI for Physiological Signals such as EMG, EEG, EOG, ECG, Hardware-Software Co-Design for AgriTech, Cryptography Accelerators, Hardware Security, In-memory-computing, Neuro</edu:description>
    <edu:fee rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rs. 77,000/- per semester: Rs. 92,000/- per semester</edu:fee>
  </rdf:Description>
