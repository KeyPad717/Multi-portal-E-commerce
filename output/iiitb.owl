  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpscagsiiitbacinevents_and_conferencesawareness_conclave_on_assistive_technologies">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Awareness Conclave on Assistive Technologies</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Awareness Conclave on Assistive Technologies</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://cags.iiitb.ac.in/events-and-conferences/awareness-conclave-on-assistive-technologies/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cags_event</edu:category>
    <edu:publishedDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">March 1, 2023</edu:publishedDate>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In association with Samarthanam Trust for the Disabled, the Centre for Accessibility in the Global South (CAGS) at IIIT Bangalore organized a one-day Awareness Conclave on Assistive Technologies (AT) on 23rd February 2023. The Conclave saw a large participation from persons with disabilities, care givers, special schools, DPOs and disability NGOs along with technology start-ups, social/impact investors, corporates, government and the academia. The Conclave sessions focused on developing better insights into the contextual realities of persons with disabilities, from an Indian/Global South pers</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:07:40</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
