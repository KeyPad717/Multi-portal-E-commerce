    edu:source "https://www.iiitb.ac.in/media/iiitbangalore-announces-admission-openings-for-phd-and-ms-by-research-programs" .

iiitb:iiit_bangalore_introduces_mtech_program_with_dual_certification_in_computer_science_and_engineering a edu:Program ;
