@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix onto: <http://iiitb.ac.in/ontology/autonomous#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

onto: a owl:Ontology ;
    dc:description "Emergent OWL ontology generated by autonomous pipeline."@en ;
    dc:title "Autonomous Institutional Knowledge Graph"@en ;
    owl:versionInfo "3.0-emergent" .

onto:IMTechECE a onto:AcademicProgramme,
        owl:NamedIndividual ;
    onto:hasBio "IIIT-B introduced a 5-year Integrated M.Tech. (I.M.Tech.) programme from 2012 onwards. The Integrated M.Tech. programme is a 5-year integrated programme intended for students who have completed or are completing Plus Two (or equivalent). At the end of five years of the programme, successful students get dual degrees of B.Tech and M.Tech. The students will be taught and supervised by the faculty members with PhD from highly reputed universities of the world and involved in R&D in niche areas of ECE." ;
    onto:hasDegree onto:BTechDegree,
        onto:MTechDegree ;
    onto:hasFacultyMember onto:ECEFacultyMember ;
    onto:hasTitle "Integrated M.Tech. (Electronics and Communication Engineering)" ;
    onto:offeredBy onto:IIITB .

onto:hasBio a owl:DatatypeProperty ;
    rdfs:comment "Represents the bio of an academic programme" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range <xsd:string> .

onto:hasDegree a owl:ObjectProperty ;
    rdfs:comment "Relates an academic programme to a degree" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range onto:Degree .

onto:hasFacultyMember a owl:ObjectProperty ;
    rdfs:comment "Relates an academic programme to a faculty member" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range onto:FacultyMember .

onto:hasTitle a owl:DatatypeProperty ;
    rdfs:comment "Represents the title of an academic programme" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range <xsd:string> .

onto:involvedIn a owl:ObjectProperty ;
    rdfs:comment "Relates a faculty member to a research area" ;
    rdfs:domain onto:FacultyMember ;
    rdfs:range onto:ResearchArea .

onto:offeredBy a owl:ObjectProperty ;
    rdfs:comment "Relates an academic programme to an institution" ;
    rdfs:domain onto:AcademicProgramme ;
    rdfs:range onto:Institution .

onto:BTechDegree a onto:Degree,
        owl:NamedIndividual ;
    rdfs:comment "Bachelor of Technology degree" .

onto:ECEFacultyMember a onto:FacultyMember,
        owl:NamedIndividual ;
    onto:involvedIn onto:ECEResearchArea .

onto:ECEResearchArea a onto:ResearchArea,
        owl:NamedIndividual ;
    rdfs:comment "Niche area of Electronics and Communication Engineering" .

onto:IIITB a onto:University,
        owl:NamedIndividual .

onto:MTechDegree a onto:Degree,
        owl:NamedIndividual ;
    rdfs:comment "Master of Technology degree" .

onto:University a owl:Class ;
    rdfs:comment "Represents a university" ;
    rdfs:subClassOf onto:Institution .

onto:Institution a owl:Class ;
    rdfs:comment "Represents an educational institution" .

onto:ResearchArea a owl:Class ;
    rdfs:comment "Represents a niche area of research" .

onto:Degree a owl:Class ;
    rdfs:comment "Represents a degree awarded to students upon completion of a programme" .

onto:FacultyMember a owl:Class ;
    rdfs:comment "Represents a faculty member involved in teaching and research" .

onto:AcademicProgramme a owl:Class ;
    rdfs:comment "Represents an academic programme offered by an institution" .

