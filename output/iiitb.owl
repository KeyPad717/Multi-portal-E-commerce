  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpsdhssiiitbacinpage2">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">DEPARTMENT OF DIGITAL HUMANITIES AND SOCIETAL SYSTEMS</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEPARTMENT OF DIGITAL HUMANITIES AND SOCIETAL SYSTEMS</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://dhss.iiitb.ac.in/page/2</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dhss_news</edu:category>
    <edu:publishedDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Oct 8, 2024</edu:publishedDate>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Exploring the intersection of technology, humanities, and society at IIIT-Bangalore. A collaborative community of scholars, researchers, and students bridging tech and social sciences. Conducting interdisciplinary research to address societal challenges through digital innovation. Offering unique programs that combine technology with humanities and social sciences. Explore diverse opportunities to engage in research, internships, and community impact. Catch up on our latest projects, events, and departmental achievements. The Department of Digital Humanities and Societal Systems (D-HSS) has be</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:17</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpsdhssiiitbacinunpacking_the_sociotechnical_imaginaries_of_dpi_workshop">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Unpacking the sociotechnical imaginaries of DPI | Workshop</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unpacking the sociotechnical imaginaries of DPI | Workshop</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://dhss.iiitb.ac.in/unpacking-the-sociotechnical-imaginaries-of-dpi-workshop/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dhss_news</edu:category>
    <edu:publishedDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jul 26, 2025</edu:publishedDate>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jul 26, 2025 | Events , Workshop A two-day workshop titled ‘Unpacking the Sociotechnical Imaginaries of Digital Public Infrastructure’ was organised at IIIT Bangalore in association with the University of Amsterdam on 24th and 25th July, 2025. The workshop aimed to bring together researchers thinking and working around different kinds of technologies called ‘DPI’, in order to foster critical discussions around the design, deployment, and practice of digital public infrastructures. The session was conducted in a hybrid format, allowing researchers based both in India and around the world to sha</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:17</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
