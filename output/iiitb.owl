  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Bhoomika_A_P">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Bhoomika A P</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bhoomika A P</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://wsl.iiitb.ac.in/bhoomika-a-p/</edu:url>
