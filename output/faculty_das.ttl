@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix onto: <http://iiitb.ac.in/ontology/autonomous#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<#Academician> a owl:Class ;
    rdfs:subClassOf <#FacultyMember> .

<#Administrator> a owl:Class .

<#ChandrashekarRamanathan> a <#Dean>,
        <#FacultyMember>,
        <#Professor>,
        owl:NamedIndividual ;
    onto:affiliatedWith <#IIITB> ;
    onto:hasBiography "Professor Chandrashekar Ramanathan is a faculty member at IIIT-B..." ;
    onto:hasEmail <mailto:rc@iiitb.ac.in> ;
    onto:hasFieldOfStudy <#DataAnalytics>,
        <#DataModeling>,
        <#DatabaseDesign>,
        <#SoftwareArchitecture> ;
    onto:hasPublication <#ResearchPaper1>,
        <#ResearchPaper2> ;
    onto:hasResearchArea <#DataScience>,
        <#LargeScaleApplicationDevelopment>,
        <#SoftwareEngineering> ;
    onto:heads <#CTRI-DG>,
        <#MINRO> ;
    onto:participatedIn <#BITES> ;
    onto:receivedAward <#Top10DataScienceAcademiciansOfIndia2018>,
        <#Top10DataScienceAcademiciansOfIndia2019> ;
    onto:servesOn <#CenterForSmartGovernance>,
        <#DepartmentOfEducation>,
        <#DepartmentOfFinance> .

<#Researcher> a owl:Class .

<#affiliatedWith> a owl:ObjectProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <#EducationInstitution> .

<#hasBiography> a owl:DatatypeProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <xsd:string> .

<#hasEmail> a owl:DatatypeProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <xsd:string> .

<#hasFieldOfStudy> a owl:ObjectProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <#FieldOfStudy> .

<#hasPublication> a owl:ObjectProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <#Publication> .

<#hasResearchArea> a owl:ObjectProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <#ResearchArea> .

<#heads> a owl:ObjectProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <#Center> .

<#participatedIn> a owl:ObjectProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <#Event> .

<#receivedAward> a owl:ObjectProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <#Award> .

<#servesOn> a owl:ObjectProperty ;
    rdfs:domain <#FacultyMember> ;
    rdfs:range <#GovernmentDepartment> .

onto: a owl:Ontology ;
    dc:description "Emergent OWL ontology generated by autonomous pipeline."@en ;
    dc:title "Autonomous Institutional Knowledge Graph"@en ;
    owl:versionInfo "3.0-emergent" .

<#BITES> a <#Board>,
        owl:NamedIndividual .

<#Board> a owl:Class ;
    rdfs:subClassOf <#Organization> .

<#CTRI-DG> a <#Center>,
        owl:NamedIndividual .

<#CenterForSmartGovernance> a <#GovernmentDepartment>,
        owl:NamedIndividual .

<#DataAnalytics> a <#FieldOfStudy>,
        owl:NamedIndividual .

<#DataModeling> a <#FieldOfStudy>,
        owl:NamedIndividual .

<#DataScience> a <#ResearchArea>,
        owl:NamedIndividual .

<#DatabaseDesign> a <#FieldOfStudy>,
        owl:NamedIndividual .

<#Dean> a owl:Class ;
    rdfs:subClassOf <#FacultyMember> .

<#DepartmentOfEducation> a <#GovernmentDepartment>,
        owl:NamedIndividual .

<#DepartmentOfFinance> a <#GovernmentDepartment>,
        owl:NamedIndividual .

<#Event> a owl:Class .

<#IIITB> a <#EducationInstitution>,
        owl:NamedIndividual .

<#LargeScaleApplicationDevelopment> a <#ResearchArea>,
        owl:NamedIndividual .

<#MINRO> a <#Center>,
        owl:NamedIndividual .

<#Professor> a owl:Class .

<#Recognition> a owl:Class .

<#ResearchOutput> a owl:Class .

<#ResearchPaper1> a <#Publication>,
        owl:NamedIndividual .

<#ResearchPaper2> a <#Publication>,
        owl:NamedIndividual .

<#SoftwareArchitecture> a <#FieldOfStudy>,
        owl:NamedIndividual .

<#SoftwareEngineering> a <#ResearchArea>,
        owl:NamedIndividual .

<#Top10DataScienceAcademiciansOfIndia2018> a <#Award>,
        owl:NamedIndividual .

<#Top10DataScienceAcademiciansOfIndia2019> a <#Award>,
        owl:NamedIndividual .

<#EducationInstitution> a owl:Class ;
    rdfs:subClassOf <#Organization> .

<#Award> a owl:Class ;
    rdfs:subClassOf <#Recognition> .

<#Center> a owl:Class ;
    rdfs:subClassOf <#Organization> .

<#Organization> a owl:Class .

<#Publication> a owl:Class ;
    rdfs:subClassOf <#ResearchOutput> .

<#GovernmentDepartment> a owl:Class .

<#ResearchArea> a owl:Class ;
    rdfs:subClassOf <#FieldOfStudy> .

<#FieldOfStudy> a owl:Class .

<#FacultyMember> a owl:Class .

