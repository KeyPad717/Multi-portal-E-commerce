<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xml:base="http://iiitb.ac.in/ontology/autonomous#"
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:onto="http://iiitb.ac.in/ontology/autonomous#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#ArtificialIntelligenceAndDataScience">
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#FieldOfStudy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:comment>Represents the field of Artificial Intelligence and Data Science</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#B_Tech_AIDS">
    <onto:hasName rdf:datatype="xsd:string">B.Tech. (Artificial Intelligence &amp; Data Science)</onto:hasName>
    <onto:hasFieldOfStudy rdf:resource="http://iiitb.ac.in/ontology/autonomous#ArtificialIntelligenceAndDataScience"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#Degree"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#FieldOfStudy">
    <rdfs:comment>Represents a field of study</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dc:title xml:lang="en">Autonomous Institutional Knowledge Graph</dc:title>
    <dc:description xml:lang="en">Emergent OWL ontology generated by autonomous pipeline.</dc:description>
    <owl:versionInfo>3.0-emergent</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Degree">
    <rdfs:subClassOf rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgram"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a degree</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#hasName">
    <rdfs:range rdf:resource="xsd:string"/>
    <rdfs:comment>Relates a degree to its name</rdfs:comment>
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#Degree"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#hasFieldOfStudy">
    <rdfs:comment>Relates a degree to its field of study</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="http://iiitb.ac.in/ontology/autonomous#FieldOfStudy"/>
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#Degree"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#AcademicProgram">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents an academic program</rdfs:comment>
  </rdf:Description>
</rdf:RDF>
