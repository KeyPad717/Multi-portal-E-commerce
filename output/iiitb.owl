  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpscagsiiitbacinauthorkartik_joshi">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
