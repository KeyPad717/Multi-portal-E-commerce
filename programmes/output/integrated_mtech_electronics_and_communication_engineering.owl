<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xml:base="http://iiitb.ac.in/ontology/autonomous#"
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:onto="http://iiitb.ac.in/ontology/autonomous#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#MTechDegree">
    <rdfs:comment>Master of Technology degree</rdfs:comment>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#Degree"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#hasTitle">
    <rdfs:comment>Represents the title of an academic programme</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
    <rdfs:range rdf:resource="xsd:string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#BTechDegree">
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#Degree"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:comment>Bachelor of Technology degree</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#hasDegree">
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment>Relates an academic programme to a degree</rdfs:comment>
    <rdfs:range rdf:resource="http://iiitb.ac.in/ontology/autonomous#Degree"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#offeredBy">
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment>Relates an academic programme to an institution</rdfs:comment>
    <rdfs:range rdf:resource="http://iiitb.ac.in/ontology/autonomous#Institution"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dc:title xml:lang="en">Autonomous Institutional Knowledge Graph</dc:title>
    <dc:description xml:lang="en">Emergent OWL ontology generated by autonomous pipeline.</dc:description>
    <owl:versionInfo>3.0-emergent</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#ECEResearchArea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#ResearchArea"/>
    <rdfs:comment>Niche area of Electronics and Communication Engineering</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#hasFacultyMember">
    <rdfs:range rdf:resource="http://iiitb.ac.in/ontology/autonomous#FacultyMember"/>
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment>Relates an academic programme to a faculty member</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#ECEFacultyMember">
    <onto:involvedIn rdf:resource="http://iiitb.ac.in/ontology/autonomous#ECEResearchArea"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#FacultyMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#IMTechECE">
    <onto:hasFacultyMember rdf:resource="http://iiitb.ac.in/ontology/autonomous#ECEFacultyMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
    <onto:hasDegree rdf:resource="http://iiitb.ac.in/ontology/autonomous#BTechDegree"/>
    <onto:hasDegree rdf:resource="http://iiitb.ac.in/ontology/autonomous#MTechDegree"/>
    <onto:hasBio>IIIT-B introduced a 5-year Integrated M.Tech. (I.M.Tech.) programme from 2012 onwards. The Integrated M.Tech. programme is a 5-year integrated programme intended for students who have completed or are completing Plus Two (or equivalent). At the end of five years of the programme, successful students get dual degrees of B.Tech and M.Tech. The students will be taught and supervised by the faculty members with PhD from highly reputed universities of the world and involved in R&amp;D in niche areas of ECE.</onto:hasBio>
    <onto:offeredBy rdf:resource="http://iiitb.ac.in/ontology/autonomous#IIITB"/>
    <onto:hasTitle>Integrated M.Tech. (Electronics and Communication Engineering)</onto:hasTitle>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#hasBio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
    <rdfs:range rdf:resource="xsd:string"/>
    <rdfs:comment>Represents the bio of an academic programme</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Degree">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a degree awarded to students upon completion of a programme</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Institution">
    <rdfs:comment>Represents an educational institution</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#involvedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#FacultyMember"/>
    <rdfs:comment>Relates a faculty member to a research area</rdfs:comment>
    <rdfs:range rdf:resource="http://iiitb.ac.in/ontology/autonomous#ResearchArea"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#ResearchArea">
    <rdfs:comment>Represents a niche area of research</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#FacultyMember">
    <rdfs:comment>Represents a faculty member involved in teaching and research</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#IIITB">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#University"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#University">
    <rdfs:subClassOf rdf:resource="http://iiitb.ac.in/ontology/autonomous#Institution"/>
    <rdfs:comment>Represents a university</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents an academic programme offered by an institution</rdfs:comment>
  </rdf:Description>
</rdf:RDF>
