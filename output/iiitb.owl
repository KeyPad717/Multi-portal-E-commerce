  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_Sushree_Sangeeta_Behera">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Sushree Sangeeta Behera</rdfs:label>
