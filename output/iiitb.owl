  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Smart_City_Lab">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Smart City Lab</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Smart City Lab</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/smart-city-lab</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_generic</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:29</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Smart city Lab (SCL) at IIITB covers monitoring several things intelligently with the help of smart sensors and AI, such as traffic; activities and authenticity of people; pollution, governance, and beneficiary schemes etc. A video surveillance system used in any smart city implementation comprises of cameras, monitors, display units, recorders and computational models for analysis and monitoring.  One such typical surveillance and monitoring system can be seen in figure below. Image Source: https://www.6gworld.com/wp-content/uploads/2021/02/SmartCitySurveillance-scaled.jpg Due to increasing population density especially in urban areas, an adequate smart infrastructure is needed to meet the needs of residents and visitors to ensure security by monitoring the real-time sensor data of a part</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
