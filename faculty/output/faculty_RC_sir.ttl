onto: a owl:Ontology ;
    dc:description "Emergent OWL ontology generated by autonomous pipeline."@en ;
    dc:title "Autonomous Institutional Knowledge Graph"@en ;
    owl:versionInfo "3.0-emergent" .

onto:Administrator a owl:Class .

onto:Awardee a owl:Class .

onto:BoardMember a owl:Class .

onto:CenterHead a owl:Class .

onto:ChandrashekarRamanathan a onto:Dean,
        onto:FacultyMember,
        onto:Professor,
        owl:NamedIndividual ;
    onto:advises onto:CenterForSmartGovernance,
        onto:DepartmentOfEducation,
        onto:DepartmentOfFinance ;
    onto:hasBio "Professor Chandrashekar Ramanathan is a faculty member at IIIT-B (International Institute of Information Technology Bangalore) since 2007 serving as professor, researcher and administrator. He has been working in the field of Computing for over 25 years in various capacities across industry and academia. He has been associated with IIITB for over 15 years where he has been teaching and carrying out research in diverse areas. His expertise lies in the fields of data science, software engineering, and large scale application development. He holds a Ph.D. degree from Mississippi State University, with his research focused on object-oriented databases. His teaching interests are in the areas of data modeling, data analytics, database design, and software architecture. His current research focus is Data Science, Model-based Software Engineering, and Technology for Education. He has authored several research papers and supervised thesis work of four PhD students, who have now graduated from IIIT-B under his guidance. He is currently heading Machine Intelligence and Robotics Center (MINRO) and Center for Technology Research and Innovation – Digital Governance (CTRI-DG), both of which are funded by Government of Karnataka. He is passionate about the use of technology for improving the quality of education. He serves on the Technical Advisory Panels of many departments of the Government of Karnataka including the Department of Education, Finance, and Center for Smart Governance. He also serves as a subject-matter expert on the Board of Studies of several HEI (Higher Educational Institutions). Dr. Chandrashekar was a Board member in the “Board for IT Education Standards (BITES)” between 2013 and 2023. He was recognized in the list of “Top 10 Data Science academicians of India” by the Analytics India magazine for the year 2018 and again in 2019."^^<xsd:string> ;
    onto:hasEmail "rc@iiitb.ac.in"^^<xsd:string> ;
    onto:hasExpertiseIn onto:DataScience,
        onto:LargeScaleApplicationDevelopment,
        onto:SoftwareEngineering ;
    onto:hasRole onto:Academician ;
    onto:hasTitle onto:ProfessorAndDeanAcademics ;
    onto:heads onto:CTRI-DG,
        onto:MINRO ;
    onto:isRecognizedBy onto:Top10DataScienceAcademiciansOfIndia2018,
        onto:Top10DataScienceAcademiciansOfIndia2019 ;
    onto:researchesIn onto:DataScience,
        onto:ModelBasedSoftwareEngineering,
        onto:TechnologyForEducation ;
    onto:servesOn onto:BoardOfStudies ;
    onto:supervises onto:PhDStudent1,
        onto:PhDStudent2,
        onto:PhDStudent3,
        onto:PhDStudent4 ;
    onto:teaches onto:DataAnalytics,
        onto:DataModeling,
        onto:DatabaseDesign,
        onto:SoftwareArchitecture ;
    onto:worksAt onto:IIITB .

