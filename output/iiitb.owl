  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_Mr_Ritesh_Kumar_IAS">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Mr. Ritesh Kumar, IAS</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mr. Ritesh Kumar, IAS</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/governing-body/mr-ritesh-kumar</edu:url>
    <edu:bio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shri Ritesh Kumar Singh, IAS, is currently the Principal Secretary, Finance Department, Government of Karnataka. A distinguished civil servant of the 1996 IAS batch (Karnataka cadre), he brings a wealth of experience in governance, finance, education, and economic policy. An alumnus of IIT Kanpur with a B.Tech. degree, he further honed his expertise with a Master’s in Public Administration in International Development (MPA/ID) from Harvard University. Throughout his illustrious career, he has held key positions such as Principal Secretary, School Education &amp; Literacy Department; Joint Secretary, Ministry of Environment, Forest &amp; Climate Change; and Senior Adviser at the India ED Office, World Bank in Washington DC. He has also served as Secretary (Expenditure) and Secretary, Revenue Department, Karnataka; Managing Director of Karnataka Power Corporation Ltd.; and Director, Economic Affairs, Ministry of Finance, Government of India. His administrative acumen extends to district governan</edu:bio>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:09:14</edu:scrapedAt>
    <edu:governs rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/placement_To_Recruit_Degree_Programmes">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#PlacementRecord"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">To Recruit Degree Programmes</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">To Recruit Degree Programmes</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/to-recruit-degree-programmes</edu:url>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Set up in the year 1998, and promoted by the Karnataka Government and the IT Industry, IIIT Bangalore attracts quality students every year from all over India and abroad, to its acclaimed Integrated M.Tech, M.Tech, MSc in Digital Society and Research Programmes. The institute has a distinguished history of producing high quality post-graduate engineers every year. The 3600+ strong alumni occupy key positions in a number of corporations, delivering tremendous value to their organizations. They have been recruited in wide range sectors like BSFI, Product, IT Services, HFTs, research labs and have assumed diversified positions ranging from SDEs, Member of Technical Staff, Technology Analyst, Technology Consultant in all levels of seniority. Students from different technical and cultural backg</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:31</edu:scrapedAt>
