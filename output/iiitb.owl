  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_SPIRAMANAYAGAM">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">S.PIRAMANAYAGAM</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">S.PIRAMANAYAGAM</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/administration/spiramanayagam</edu:url>
    <edu:bio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">He has joined as Chief Finance Officer at IIITB. An Associate Member of The Institute of Chartered Accountants of India of 1987 batch. HE has served in various capacities in  Neyveli Lignite Corporation Ltd, BEML and Bharat Dynamics Ltd. Before joining IIITB as Chief Finance Officer in Oct 20, he served on the board of Bharat Dynamics Ltd as Director (Finance) for five and half years. He also managed HR portfolio during his stint as Director (Finance). He has vast experience in Accounting, Auditing, Finance and Taxation.</edu:bio>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:34</edu:scrapedAt>
    <edu:governs rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Natarajan_S">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Natarajan S</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natarajan S</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/iiitb-innovation-center/natarajan-s</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_generic</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:09:17</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">natarajan [dot] s [at] iiitb [dot] ac [dot] in Natarajan is an NIT Nagpur Alumni and spent most of his twenty five years career in building tech products in computer, networking &amp; communication domains and taking them to market for product companies including Intel &amp; D-Link. He has been involved with the startup ecosystem for the last six years sharing his knowledge and experience in guiding product startups. In addition to starting a corporate startup incubation at Intel India, he was  associated with DERBI Foundation as well as SINE IIT Mumbai for mentoring and other startup ecosystem activities. At IIITB innovation center, Natarajan would be providing support for the center's strategic directions and guiding the startups for product market fit.</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
