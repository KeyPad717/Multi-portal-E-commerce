  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#ProfessorAndDeanAcademics">
    <rdfs:comment>Section of a faculty member's profile</rdfs:comment>
    <onto:content rdf:resource="http://iiitb.ac.in/ontology/autonomous#rc_at_iiitb_ac_dot_in_Education_Phd_MississippiStateUniversity_ProfessorChandrashekarRamanathan_is_a_faculty_member_at_IIIT-B_since_2007_serving_as_professor_researcher_and_administrator_He_has_been_working_in_the_field_of_Computing_for_over_25_years_in_various_capacities_across_industry_and_academia_He_has_been_associated_with_IIITB_for_over_15_years_where_he_has_been_teaching_and_carrying_out_research_in_diverse_areas_His_expertise_lies_in_the_fields_of_data_science_software_engineering_and_large_scale_application_development_He_holds_a_Phd_degree_from_Mississippi_State_University_with_his_research_focused_on_object_oriented_databases_His_teaching_interests_are_in_the_areas_of_data_modeling_data_analytics_database_design_and_software_architecture_His_current_research_focus_is_Data_Science_Model_based_Software_Engineering_and_Technology_for_Education_He_has_authored_several_research_papers_and_supervised_thesis_work_of_four_Phd_students_who_have_now_graduated_from_IIIT-B_under_his_guidance_He_is_currently_heading_Machine_Intelligence_and_Robotics_Center_and_Center_for_Technology_Research_and_Innovation_Digital_Governance_both_of_which_are_funded_by_Government_of_Karnataka_He_is_passionate_about_the_use_of_technology_for_improving_the_quality_of_education_He_serves_on_the_Technical_Advisory_Panels_of_many_departments_of_the_Government_of_Karnataka_including_the_Department_of_Education_Finance_and_Center_for_Smart_Governance_He_also_serves_as_a_subject_matter_expert_on_the_Board_of_Studies_of_several_HEI_Higher_Educational_Institutions_Dr_Chandrashekar_was_a_Board_member_in_the_Board_for_IT_Education_Standards_between_2013_and_2023_He_was_recognized_in_the_list_of_Top_10_Data_Science_academicians_of_India_by_the_Analytics_India_magazine_for_the_year_2018_and_again_in_2019"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Professor &amp; Dean (Academics)</rdfs:label>
  </rdf:Description>
