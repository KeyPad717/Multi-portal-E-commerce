  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpscagsiiitbacinevents_and_conferencesdesign_thinking_workshop_on_accessible_education_2">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Design Thinking Workshop on Accessible Education</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Design Thinking Workshop on Accessible Education</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://cags.iiitb.ac.in/events-and-conferences/design-thinking-workshop-on-accessible-education-2/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cags_event</edu:category>
    <edu:publishedDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">February 24, 2023</edu:publishedDate>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CAGS hosted a Design Thinking Workshop on 20th January 2023 on accessible education for students with visual impairment to a group of students from New Zealand who were on an educational visit to IIIT Bangalore. The workshop intended to provide a deeper understanding on the diversity of students, current state of STEM education and other aspects of the education system for persons with disabilities. The workshop also involved participation from IIIT Bangalore students who worked in groups with New Zealand participants and identified challenges in the education system for students with visual i</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:07:43</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
