    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sridhar Pillalamarri</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/iiitb-comet-foundation/sridhar-pillalamarri</edu:url>
