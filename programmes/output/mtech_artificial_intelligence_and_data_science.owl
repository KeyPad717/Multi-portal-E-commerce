<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xml:base="http://iiitb.ac.in/ontology/autonomous#"
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:onto="http://iiitb.ac.in/ontology/autonomous#"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#hasSection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="http://iiitb.ac.in/ontology/autonomous#Section"/>
    <rdfs:comment>Relates an academic programme to its sections</rdfs:comment>
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Section">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a section or component of a programme</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Goal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a goal or objective</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dc:title xml:lang="en">Autonomous Institutional Knowledge Graph</dc:title>
    <dc:description xml:lang="en">Emergent OWL ontology generated by autonomous pipeline.</dc:description>
    <owl:versionInfo>3.0-emergent</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Internships">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#Section"/>
    <rdfs:comment>Internships</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#M_Tech_AIDS">
    <onto:hasGoal rdf:resource="http://iiitb.ac.in/ontology/autonomous#DevelopProfessionals"/>
    <onto:hasSection rdf:resource="http://iiitb.ac.in/ontology/autonomous#Internships"/>
    <onto:hasSection rdf:resource="http://iiitb.ac.in/ontology/autonomous#Courses"/>
    <onto:hasSection rdf:resource="http://iiitb.ac.in/ontology/autonomous#Research"/>
    <onto:hasSection rdf:resource="http://iiitb.ac.in/ontology/autonomous#ProjectWork"/>
    <onto:hasSection rdf:resource="http://iiitb.ac.in/ontology/autonomous#Seminars"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#PostgraduateProgramme"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme">
    <rdfs:comment>Represents a programme of study</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#ProjectWork">
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#Section"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:comment>Project work</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#DevelopProfessionals">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#EducationGoal"/>
    <rdfs:comment>Develop professionals of high quality</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Seminars">
    <rdfs:comment>Seminars</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#Section"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Research">
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#Section"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:comment>Research leading to a thesis</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#Courses">
    <rdf:type rdf:resource="http://iiitb.ac.in/ontology/autonomous#Section"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:comment>Courses of study</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#PostgraduateProgramme">
    <rdfs:comment>Represents a postgraduate programme of study</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#hasGoal">
    <rdfs:range rdf:resource="http://iiitb.ac.in/ontology/autonomous#Goal"/>
    <rdfs:domain rdf:resource="http://iiitb.ac.in/ontology/autonomous#AcademicProgramme"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:comment>Relates an academic programme to its goals</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://iiitb.ac.in/ontology/autonomous#EducationGoal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>Represents a goal related to education</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://iiitb.ac.in/ontology/autonomous#Goal"/>
  </rdf:Description>
</rdf:RDF>
