  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_T_K_Srikanth">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">T K Srikanth</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">T K Srikanth</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/iiitb-ehrc/t-k-srikanth</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_generic</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:35</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tk [dot] srikanth [at] iiitb [dot] ac [dot] in Education : Ph.D. (Cornell University) Dr. Srikanth obtained his Ph.D. in Computer Science from Cornell University in 1986, and a B.Tech (Mech. Eng) from the Indian Institute of Technology, Madras. His research interests are in the areas of mobile and internet based applications, eHealth, data privacy, Computer Graphics, Geometric Modeling and 3D Printing, He is a co-convenor of the E-Health Research Center at IIITB (ehrc.iiitb.ac.in), and is actively involved in multipe collaborative research projects in healthcare, with a focus on mental health and public health. His team at EHRC has designed and developed healthcare solutions that have been deployed at the national and state levels. Prior to joining IIITB, he had over 28 years of experience</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_Dr_Manjula_N_IAS">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Dr. Manjula N, I.A.S</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dr. Manjula N, I.A.S</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/governing-body/dr-manjula-n-ias</edu:url>
    <edu:bio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dr. N. Manjula, IAS (2002 batch) is a distinguished administrator known for pioneering leadership, inclusive governance, and results-driven public service. A qualified medical professional (MBBS) prior to joining the civil services, she brings a rare blend of scientific training and citizen-centric empathy to complex administrative responsibilities. As Secretary to Government, Department of Electronics, Information Technology, Biotechnology and Science &amp; Technology (El, IT, Bt &amp; S&amp;T), Government of Karnataka, Dr. Manjula provides strategic direction to the State’s technology-led growth agenda, strengthening innovation systems, enabling policy reforms, and accelerating outcomes across emerging technology domains. Policy leadership and recent interventions In her current role, Dr. Manjula has helped steer Karnataka’s next phase of startup- and innovation-led growth, strengthening the policy-and-program backbone that enables entrepreneurs, deep-tech talent, and industry collaboration at s</edu:bio>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:09:14</edu:scrapedAt>
    <edu:governs rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
