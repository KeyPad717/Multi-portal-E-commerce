  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/news_httpsdhssiiitbacinan_emergent_social_contract_for_a_digital_world_asilata_karandikar_and_prof_v_sridhar">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#NewsItem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">An Emergent Social Contract for a Digital World: Asilata Karandikar and Prof V. Sridhar</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An Emergent Social Contract for a Digital World: Asilata Karandikar and Prof V. Sridhar</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://dhss.iiitb.ac.in/an-emergent-social-contract-for-a-digital-world-asilata-karandikar-and-prof-v-sridhar/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dhss_news</edu:category>
    <edu:publishedDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sep 26, 2025</edu:publishedDate>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sep 26, 2025 | Faculty Spotlight , Publications &amp; Conferences , Research Roundup With rapid digital transformation, how could we, as citizens of India, better understand our roles and actions when it comes to the realm of privacy? More importantly, what safeguards apply to us within this realm? These are questions that have puzzled us for a while now and many of us are often lost, especially when there is legal parlance involved. Researchers at DHSS, IIIT-Bangalore are attempting to unpack them. Our doctoral scholar Asilata Karandikar under the supervision of Prof. V. Sridhar attempts to decon</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:02</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
