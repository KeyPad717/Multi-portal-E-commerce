    <edu:heading rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Project Descriptions</edu:heading>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
