  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/governance_Dinesh_Babu_Jayagopi">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#GovernanceMember"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Dinesh Babu Jayagopi</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinesh Babu Jayagopi</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/administration/dinesh-babu-jayagopi</edu:url>
    <edu:bio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Education : Ph.D. (École Polytechnique Fédérale de Lausanne) Prof. Dinesh Babu Jayagopi is currently the Head of Data Science and AI (DSAI) department at IIIT Bangalore, where he heads the Multimodal Perception Lab.  His research interests are in Audio-Visual Signal Processing, Machine Learning, and Social Computing. He obtained his doctorate from Ecole Polytechnic Federale Lausanne (EPFL), Switzerland, beginning of 2011. He received the National Teachers Award from the President of India in the Year 2023. He received the Outstanding paper award in the International Conference on Multimodal Interaction (ICMI), 2012, Idiap Best PhD student research award for the year 2009. More recently, His joint work with an MS student received IAPR Best student paper award in International Conference on Computer Vision and Image Processing (CVIP) 2024. His PhD student's work was nominated for Best student paper in ICMI 2016 Tokyo, Japan. He also received Department of Science and Technology (DST) You</edu:bio>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:33</edu:scrapedAt>
    <edu:governs rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_IndicNLP">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">IndicNLP</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IndicNLP</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://wsl.iiitb.ac.in/indicnlp/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_wsl</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:19</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IndicNLP project focuses on building an knowledge management framework for oral community knowledge in low-resource and colloquial Kannada language. Knowledge in rural communities is largely created, preserved, and is transferred verbally, and it is limited. This information is valuable to these communities, and managing and making it available digitally with state-of-the-art approaches enriches awareness and collective knowledge of people of these communities. The large amounts of data and information produced on the Internet are inaccessible to the population in these rural communities due to factors like lack of infrastructure, connectivity, and limited literacy. Knowledge internal to rural communities is also not conserved and made available in any global Big Data information systems.</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/student_activity_Placement_Committee">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#StudentActivity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Placement Committee</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Placement Committee</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/committees-clubs/committees/placement-committee</edu:url>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Placement Committee at IIIT Bangalore, comprising final-year students, serves as a vital link between the student community and the numerous companies that visit our campus. The committee supports students in their placement preparation and coordinates the end-to-end execution of on-campus recruitment drives. Being part of this committee offers the opportunity to interact with every member of the graduating batch, and witnessing each student secure their placement is an experience of immense pride and fulfilment. The committee also works closely with the Institute’s Placement Cell, adminis</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:37</edu:scrapedAt>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
