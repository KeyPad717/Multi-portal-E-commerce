  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/student_activity_Alumni">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#StudentActivity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Alumni</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alumni</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/alumni</edu:url>
    <edu:body rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IIIT-Bangalore alumni consisting of over 3500 graduates (as on July 2021) are the true ambassadors of the Institute. They occupy key positions in major Indian and international corporations and are actively engaged in mentoring current students on the campus. Our alumni are spread all across the world and have achieved various feats as researchers and entrepreneurs. Network : The alumni association is an immense network of professional contacts—all with whom you already have one thing in common. Need to get a foot in the door for your next job, or curious if an organization that’s pursuing you</edu:body>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:22</edu:scrapedAt>
    <edu:heading rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Welcome to the IIIT-Bangalore Alumni Page: Donate Sign Up</edu:heading>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
