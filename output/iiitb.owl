  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Web_Science_Lab">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Web Science Lab</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Web Science Lab</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://wsl.iiitb.ac.in/</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_wsl</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:08:18</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Web Science Lab (WSL) at IIIT Bangalore is interested in understanding how the Internet, WWW and AI affects different facets of human life. The Internet, WWW and now AI have brought about massive changes on human life in just about all facets– be it in business, administration, social well-being, personal relationships, education, etc. While these technologies continue to evolve at a rapid pace, there is relatively little attention given to how we as humans are transforming in this new world. The idea of Web Science was formally coined by the establishment of the Web Science Trust Network (WSTNet) in 2006, comprising of multiple research labs around the world. WSL at IIITB is a part of the global WSTNet. The book “ The Power Law of Information: Life in a Connected World ” written in 20</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
