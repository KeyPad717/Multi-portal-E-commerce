  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/lab_Swathy_V">
    <rdf:type rdf:resource="http://semanticweb.iiitb.ac.in/edu#Lab"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">Swathy V</rdfs:label>
    <edu:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swathy V</edu:name>
    <edu:url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.iiitb.ac.in/iiitb-innovation-center/swathy-v</edu:url>
    <edu:category rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lab_generic</edu:category>
    <edu:scrapedAt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-03-26T19:09:16</edu:scrapedAt>
    <edu:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">swathy [dot] v [at] iiitb [dot] ac [dot] in Swathy brings over 9 years of experience in startup incubation, ecosystem development, and program management. She holds an MBA and an engineering degree, with a strong track record of supporting early-stage ventures and building innovation-focused programs. As the Incubation Manager at IIITB Innovation Centre, Swathy leads strategic initiatives across fintech and other emerging domains, working closely with startups, corporates, and government bodies. Her role spans managing incubation and pre-incubation cohorts, forging key partnerships, and organizing high-impact events, mentorship sessions, and capacity-building interventions to strengthen the innovation ecosystem.</edu:description>
    <edu:belongsTo rdf:resource="http://semanticweb.iiitb.ac.in/iiitb/IIIT_Bangalore"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://semanticweb.iiitb.ac.in/iiitb/program_Visvesvaraya_PhD_Scheme">
